# Dashboard Environment Variables
# Copy this file to .env.local and fill in the values

# Contract package ID (required — from deployment)
NEXT_PUBLIC_VAULT_PACKAGE_ID=

# Default vault to show on the landing page (optional — auto-discovered if empty)
NEXT_PUBLIC_DEFAULT_VAULT_ID=

# Walrus aggregator for fetching reasoning blobs
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Sui network (testnet or mainnet)
NEXT_PUBLIC_SUI_NETWORK=testnet

# Agent wallet address (for admin page auto-authorization)
NEXT_PUBLIC_AGENT_ADDRESS=

# Groq API key for AI configuration assistant (server-side only)
GROQ_API_KEY=your_groq_api_key_here
