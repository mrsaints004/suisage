# ============================================================
# SuiSage Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- REQUIRED: Core Setup ---

# Sui network: testnet | mainnet | devnet
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Agent wallet private key (bech32 "suiprivkey..." or base64)
# Generate with: sui keytool generate ed25519
AGENT_PRIVATE_KEY=

# Package ID from contract deployment (run scripts/deploy.sh)
VAULT_PACKAGE_ID=

# AI provider (at least one required)
GROQ_API_KEY=

# --- OPTIONAL: Single-Vault Mode ---
# Leave empty to use auto-discovery (recommended for multi-vault)

VAULT_OBJECT_ID=
AGENT_CAP_ID=
STRATEGY_CONFIG_ID=

# --- OPTIONAL: Agent Public Address ---
# Derived from AGENT_PRIVATE_KEY automatically if not set
AGENT_ADDRESS=

# --- REQUIRED: DeepBook ---

DEEPBOOK_PACKAGE_ID=0xdee9
# SUI/wUSDC pool (mainnet default below, change for testnet)
DEEPBOOK_POOL_ID=0x4405b50d791fd3346754e8171aaab6bc2ed26c2c46efdd033c14b30ae507ac33
# Auto-created on first trade if empty
ACCOUNT_CAP_ID=

# --- REQUIRED: Walrus (reasoning storage) ---

WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# --- OPTIONAL: Telegram Bot ---
# Get token from @BotFather on Telegram
# When set, the bot starts automatically with the agent
TELEGRAM_BOT_TOKEN=

# --- OPTIONAL: MemWal (persistent agent memory) ---
# Get credentials from https://memory.walrus.xyz
MEMWAL_DELEGATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz

# --- OPTIONAL: Seal (encrypted reasoning) ---
# Deploy seal_approve Move module first, then set these
SEAL_PACKAGE_ID=
SEAL_POLICY_ID=
SEAL_KEY_SERVER_OBJECT_ID=

# --- OPTIONAL: DeepBook Predict (testnet only) ---
PREDICT_ENABLED=false
PREDICT_PACKAGE_ID=
PREDICT_REGISTRY_ID=
PREDICT_MANAGER_ID=
PREDICT_RPC_URL=https://fullnode.testnet.sui.io:443
DUSDC_COIN_TYPE=

# --- OPTIONAL: Anthropic API (alternative to Groq) ---
ANTHROPIC_API_KEY=

# --- Agent Settings ---

AGENT_ID=primary
AGENT_LOOP_INTERVAL_MS=60000
MAX_TRADE_SIZE_SUI=10
DISCOVERY_REFRESH_MS=300000
