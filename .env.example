# Sui Network
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# Agent wallet (private key in bech32 suiprivkey... format)
AGENT_PRIVATE_KEY=

# Contract addresses (set after deploying contracts)
VAULT_PACKAGE_ID=
VAULT_OBJECT_ID=
AGENT_CAP_ID=
STRATEGY_CONFIG_ID=

# DeepBook V2 (mainnet)
DEEPBOOK_PACKAGE_ID=0xdee9
# SUI/wUSDC low-fee pool (0.02% taker/maker)
DEEPBOOK_POOL_ID=0x4405b50d791fd3346754e8171aaab6bc2ed26c2c46efdd033c14b30ae507ac33
# DeepBook AccountCap (auto-created on first trade if empty)
ACCOUNT_CAP_ID=

# DeepBook Predict (testnet — optional)
PREDICT_PACKAGE_ID=
PREDICT_REGISTRY_ID=
PREDICT_MANAGER_ID=
PREDICT_RPC_URL=https://fullnode.testnet.sui.io:443
DUSDC_COIN_TYPE=

# Walrus (testnet - walrus mainnet not yet live)
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# MemWal — Persistent, encrypted agent memory on Walrus (optional)
# Get credentials from https://memory.walrus.xyz
MEMWAL_DELEGATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz

# Seal — Encrypted reasoning (optional)
# Deploy seal_approve Move module first, then set these
SEAL_PACKAGE_ID=
SEAL_POLICY_ID=
SEAL_KEY_SERVER_OBJECT_ID=

# Claude API
ANTHROPIC_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Agent settings
AGENT_LOOP_INTERVAL_MS=60000
MAX_TRADE_SIZE_SUI=10

# Dashboard (set these as NEXT_PUBLIC_ vars in dashboard/.env.local)
# NEXT_PUBLIC_VAULT_PACKAGE_ID=
# NEXT_PUBLIC_VAULT_OBJECT_ID=
# NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
